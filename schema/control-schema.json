{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Traceable machine-readable control derived from a legal norm",
  "type": "object",
  "$defs": {
    "human_confirmation_record": {
      "type": "object",
      "required": ["confirmed", "value", "reviewer_role", "reviewed_at"],
      "properties": {
        "confirmed": { "const": true },
        "value": {},
        "reviewer_role": { "type": "string", "minLength": 1 },
        "reviewer_name": { "type": ["string", "null"] },
        "reviewed_at": { "type": "string", "minLength": 1 },
        "review_note": { "type": "string" }
      }
    },
    "human_review_record": {
      "type": "object",
      "required": ["completed", "result"],
      "properties": {
        "completed": { "type": "boolean" },
        "result": { "enum": ["pass", "fail", null] },
        "reviewer_role": { "type": "string" },
        "reviewer_name": { "type": ["string", "null"] },
        "reviewed_at": { "type": "string" },
        "review_note": { "type": "string" }
      }
    }
  },
  "required": ["control_id", "norm_id", "control_component", "control_derivation_type", "control_objective", "applicability", "evidence", "test", "outcomes", "automation_level", "traceability", "review"],
  "properties": {
    "control_id": { "type": "string" },
    "norm_id": { "type": "string" },
    "control_component": { "type": "string", "minLength": 1 },
    "control_derivation_type": {
      "enum": ["direct_legal_requirement", "derived_organizational_control", "technical_implementation_control"]
    },
    "control_objective": { "type": "string" },
    "applicability": {
      "type": "object",
      "required": ["conditions"],
      "properties": {
        "conditions": { "type": "object" },
        "not_applicable_when": { "type": "object" },
        "human_confirmed_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "exception_path": {
      "type": "object",
      "required": ["expression", "required_fields", "outcome", "control_scope", "lifecycle_stage"],
      "properties": {
        "expression": { "type": "string" },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outcome": { "enum": ["pass", "review", "not_applicable"] },
        "message": { "type": "string" },
        "control_scope": { "type": "string", "minLength": 1 },
        "lifecycle_stage": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["evidence_type", "required_fields"],
      "properties": {
        "evidence_type": { "type": "string" },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "test": {
      "type": "object",
      "required": ["expression"],
      "properties": {
        "expression": { "type": "string" }
      }
    },
    "outcomes": {
      "type": "object",
      "required": ["pass", "fail", "review", "not_applicable"],
      "properties": {
        "pass": { "type": "string" },
        "fail": { "type": "string" },
        "review": { "type": "string" },
        "not_applicable": { "type": "string" }
      }
    },
    "automation_level": {
      "enum": ["fully_automatable", "partially_automatable", "human_review_required"]
    },
    "required_human_review": {
      "type": "object",
      "required": ["review_key"],
      "properties": {
        "review_key": { "type": "string", "minLength": 1 }
      }
    },
    "traceability": {
      "type": "object",
      "required": [
        "source_id",
        "document_title_zh",
        "document_title_en",
        "article",
        "effective_date",
        "source_url",
        "source_url_specificity",
        "normative_fragment",
        "interpretation_version"
      ],
      "properties": {
        "source_id": { "type": "string" },
        "document_title_zh": { "type": "string" },
        "document_title_en": { "type": "string" },
        "article": { "type": "string" },
        "effective_date": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "source_url_specificity": {
          "enum": ["article_page", "document_page", "registry_page", "institution_homepage"]
        },
        "normative_fragment": { "type": "string" },
        "interpretation_version": { "type": "string" }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "author_review_status",
        "legal_expert_review_status",
        "reviewer_role",
        "reviewer_name",
        "review_date",
        "interpretation_version",
        "review_notes"
      ],
      "properties": {
        "author_review_status": {
          "enum": ["not_reviewed", "under_review", "reviewed", "disputed", "superseded"]
        },
        "legal_expert_review_status": {
          "enum": ["not_reviewed", "under_review", "reviewed", "disputed", "superseded"]
        },
        "reviewer_role": { "type": "string" },
        "reviewer_name": { "type": ["string", "null"] },
        "review_date": { "type": "string" },
        "interpretation_version": { "type": "string" },
        "review_notes": { "type": "string" }
      }
    }
  }
}
