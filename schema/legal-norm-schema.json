{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Human-reviewed legal norm for machine-readable AIGC controls",
  "type": "object",
  "required": ["norm_id", "source", "norm", "interpretation", "evidence", "test", "review"],
  "properties": {
    "norm_id": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": [
        "source_id",
        "document_title_zh",
        "document_title_en",
        "issuing_authority",
        "article",
        "source_text_zh",
        "working_translation_en",
        "source_url",
        "source_url_specificity",
        "promulgation_date",
        "effective_date",
        "retrieved_at",
        "source_snapshot"
      ],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "document_title_zh": { "type": "string", "minLength": 1 },
        "document_title_en": { "type": "string", "minLength": 1 },
        "issuing_authority": { "type": "string", "minLength": 1 },
        "article": { "type": "string", "minLength": 1 },
        "source_text_zh": { "type": "string", "minLength": 1 },
        "working_translation_en": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "source_url_specificity": {
          "enum": ["article_page", "document_page", "registry_page", "institution_homepage"]
        },
        "promulgation_date": { "type": "string" },
        "effective_date": { "type": "string" },
        "retrieved_at": { "type": "string" },
        "source_snapshot": {
          "type": "object",
          "required": ["retrieved_at", "source_excerpt_sha256", "source_document_sha256", "verification_status"],
          "properties": {
            "retrieved_at": { "type": "string" },
            "source_excerpt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "source_document_sha256": { "type": ["string", "null"] },
            "verification_status": {
              "enum": ["metadata_only", "snapshot_verified", "manually_verified_against_official_source"]
            }
          }
        }
      }
    },
    "norm": {
      "type": "object",
      "required": ["regulated_actor", "modality", "action", "object", "trigger", "exceptions"],
      "properties": {
        "regulated_actor": { "type": "string" },
        "modality": { "enum": ["must", "must_not", "may"] },
        "action": { "type": "string" },
        "object": { "type": "string" },
        "trigger": { "type": "object" },
        "exceptions": { "type": "array" },
        "deadline_or_timing": { "type": "string" }
      }
    },
    "interpretation": {
      "type": "object",
      "required": ["control_objective", "automation_level", "ambiguity_level", "reviewer_note"],
      "properties": {
        "control_objective": { "type": "string" },
        "automation_level": {
          "enum": ["fully_automatable", "partially_automatable", "human_review_required"]
        },
        "ambiguity_level": { "enum": ["low", "medium", "high"] },
        "reviewer_note": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["evidence_type", "required_fields"],
      "properties": {
        "evidence_type": { "type": "string" },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "test": {
      "type": "object",
      "required": ["expression", "pass_condition", "fail_condition", "review_condition"],
      "properties": {
        "expression": { "type": "string" },
        "pass_condition": { "type": "string" },
        "fail_condition": { "type": "string" },
        "review_condition": { "type": "string" }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "author_review_status",
        "legal_expert_review_status",
        "reviewer_role",
        "reviewer_name",
        "review_date",
        "interpretation_version",
        "review_notes"
      ],
      "properties": {
        "author_review_status": {
          "enum": ["not_reviewed", "under_review", "reviewed", "disputed", "superseded"]
        },
        "legal_expert_review_status": {
          "enum": ["not_reviewed", "under_review", "reviewed", "disputed", "superseded"]
        },
        "reviewer_role": { "type": "string" },
        "reviewer_name": { "type": ["string", "null"] },
        "review_date": { "type": "string" },
        "interpretation_version": { "type": "string" },
        "review_notes": { "type": "string" }
      }
    }
  }
}
